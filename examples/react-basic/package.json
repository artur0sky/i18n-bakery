{
    "name": "example-react-app",
    "private": true,
    "version": "0.0.0",
    "dependencies": {
        "@i18n-bakery/core": "workspace:*",
        "@i18n-bakery/react": "workspace:*",
        "react": "19.2.3",
        "react-country-flag": "3.1.0",
        "react-dom": "19.2.3",
        "tailwind-merge": "3.4.0"
    },
    "devDependencies": {
        "@i18n-bakery/cli": "workspace:*",
        "@i18n-bakery/tray": "workspace:*",
        "@tabler/icons-react": "3.36.0",
        "@tailwindcss/vite": "4.1.17",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.1",
        "autoprefixer": "10.4.22",
        "postcss": "8.5.6",
        "tailwindcss": "4.1.17",
        "tailwindcss-patch": "8.4.2",
        "unplugin-tailwindcss-mangle": "5.0.0",
        "vite": "7.3.0",
        "wouter": "3.8.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "i18n:extract": "i18n-bakery batter src --locale en-US,es-MX,it,jp --out public/locales --purge",
        "i18n:bake": "i18n-bakery bake public/locales --split --manifest manifest.json",
        "i18n:tray": "i18n-bakery-tray"
    }
